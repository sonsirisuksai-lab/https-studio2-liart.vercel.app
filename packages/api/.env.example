# ============================================================
# COSMOS API — Environment Variables
# Copy to .env and fill in real values before running.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Supabase (server-side — use SERVICE ROLE key, not anon key)
# Find in Supabase: Settings > API > service_role
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# AI Keys (optional — used when real LLM dispatch is wired up)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Token Budget Limits (optional overrides)
TOKEN_LIMIT_ROBIN=8000
TOKEN_LIMIT_STARLIGHT=12000
TOKEN_LIMIT_SYSTEM=4000
