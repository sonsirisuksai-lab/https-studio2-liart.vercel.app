# ============================================================
# COSMOS API — Environment Variables
# Copy to .env and fill in real values before running.
# ============================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your Vercel domain in prod.
CORS_ORIGIN=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Server-side SERVICE ROLE key only — never expose to the browser.
# Find in Supabase: Settings > API > service_role
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Gemini (Google Gen AI) ────────────────────────────────────────────────────
# Required for the real agent loop. Without this, neuralGrid falls back to mock
# responses automatically — safe for local dev without an API key.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Other AI providers (optional — for future OpenRouter/Claude support) ──────
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Token Budget Limits ───────────────────────────────────────────────────────
# Per-agent token caps (tokens per session window).
# Tune these based on your Gemini quota and expected traffic.
TOKEN_LIMIT_ROBIN=8000
TOKEN_LIMIT_STARLIGHT=12000
TOKEN_LIMIT_SYSTEM=4000

# ── Token Guard / Critical Threshold ─────────────────────────────────────────
# Percentage of budget remaining below which the tokenGuard middleware
# blocks the request and returns a 503 + cached fallback.
# Both names are accepted; TOKEN_CRITICAL_THRESHOLD takes precedence if set.
# Default: 5  (agent must have > 5% budget left to serve a live response)
TOKEN_CRITICAL_THRESHOLD=5
TOKEN_GUARD_THRESHOLD_PCT=5

# ── WebSocket Auth ────────────────────────────────────────────────────────────
# Set to "true" in production to require a valid Supabase JWT on WS connections.
# When true, clients must connect as:
#   wss://your-host/api/ws/cosmos?token=<supabase-access-token>
# In dev (default: false) connections are accepted without a token.
WS_AUTH_REQUIRED=false
