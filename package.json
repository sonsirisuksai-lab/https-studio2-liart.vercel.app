{
  "name": "cosmos-os",
  "version": "5.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @cosmos/web",
    "dev:web": "npm run dev -w @cosmos/web",
    "dev:mobile": "npm run start -w @cosmos/mobile",
    "dev:desktop": "npm run dev -w @cosmos/desktop",
    "build": "npm run build -w @cosmos/web && mkdir -p dist && cp -rv packages/web/dist/* dist/",
    "build:web": "npm run build -w @cosmos/web",
    "lint": "npm run lint -w @cosmos/web",
    "test": "vitest run",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/matter-js": "^0.20.2",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-legacy": "^8.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@sentry/react": "^10.63.0",
    "@supabase/supabase-js": "^2.110.0",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "express-rate-limit": "^8.5.2",
    "html5-qrcode": "^2.3.8",
    "jszip": "^3.10.1",
    "matter-js": "^0.20.0",
    "web-vitals": "^5.3.0",
    "zustand": "^5.0.14"
  }
}
