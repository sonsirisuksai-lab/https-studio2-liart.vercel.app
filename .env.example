# COSMOS v5.0 — ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to '.env' at the project root and fill in your real credentials.

# --------------------------------------------------------------------
# App Core Settings
# --------------------------------------------------------------------
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME="COSMOS OS"

# --------------------------------------------------------------------
# Supabase Cloud Synchronization & Authentication Settings
# --------------------------------------------------------------------
# Find these in your Supabase Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# --------------------------------------------------------------------
# Optional AI Integration Settings (Gemini / OpenAI)
# --------------------------------------------------------------------
# VITE_GEMINI_API_KEY=your-gemini-api-key
# VITE_OPENAI_API_KEY=your-openai-api-key
